---
import type { GalleryCategory } from '../data/gallery';

interface Props {
  category: GalleryCategory;
}
const { category } = Astro.props;
---

<section id={category.id} class="gallery-section mb-12 scroll-mt-20">
  <h2 class="font-display text-2xl font-bold text-stone-900 mb-6 pb-3 border-b-2 border-brand-200">
    {category.title}
  </h2>
  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
    {category.images.map((img) => (
      <a
        href={img.fullSrc}
        data-pswp-width={img.width}
        data-pswp-height={img.height}
        data-cropped="true"
        class="group block overflow-hidden rounded-lg bg-stone-200 aspect-[4/3]"
      >
        <img
          src={img.thumbSrc}
          alt={img.caption}
          loading="lazy"
          class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
        />
      </a>
    ))}
  </div>
</section>
