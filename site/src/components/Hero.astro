---
---

<section
  class="relative min-h-[90vh] flex items-end bg-cover bg-center bg-no-repeat"
  style="background-image: url('/images/hero.jpg')"
>
  <!-- Gradient: dark on left, fades to transparent right -->
  <div class="absolute inset-0 bg-gradient-to-r from-stone-950/80 via-stone-950/40 to-transparent"></div>
  <!-- Bottom fade for text legibility -->
  <div class="absolute inset-0 bg-gradient-to-t from-stone-950/50 via-transparent to-transparent"></div>

  <!-- Content — left-aligned, bottom of viewport -->
  <div class="relative z-10 w-full max-w-6xl mx-auto px-6 pb-20 pt-32">
    <p class="text-stone-300 text-sm font-medium tracking-widest uppercase mb-5">
      Custom Kitchens &middot; South Australia &middot; Est. 1996
    </p>
    <h1 class="font-display text-5xl md:text-6xl lg:text-7xl font-extrabold text-white mb-6 leading-[1.05] max-w-2xl">
      Kitchens Built<br />For How You Live
    </h1>
    <p class="text-stone-300 text-lg mb-10 max-w-md leading-relaxed">
      Custom-designed and hand-crafted in Adelaide, with over two decades of experience.
    </p>
    <div class="flex flex-col sm:flex-row gap-4">
      <a
        href="/#contact"
        class="inline-flex items-center justify-center gap-2 px-7 py-3.5 bg-brand-600 text-white rounded font-semibold hover:bg-brand-700 transition-colors text-sm"
      >
        Book a Free Assessment
      </a>
      <a
        href="/gallery/"
        class="inline-flex items-center justify-center gap-2 px-7 py-3.5 border border-white/60 text-white rounded font-semibold hover:bg-white/10 transition-colors text-sm"
      >
        See Our Work
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>
